# ── Project ───────────────────────────────────────────────────
# Used as prefix for Docker container names.
# Each team uses a different name to avoid conflicts on shared machines.
# Example: unisa-g1, unisa-g2
PROJECT_NAME=sandbox

# ── App ───────────────────────────────────────────────────────
APP_ENV=local

# ── Postgres ──────────────────────────────────────────────────
DB_USER=sandbox
DB_PASSWORD=sandbox
DB_NAME=sandbox_db
DB_HOST=postgres
# External port — change this if 5432 is already in use on your machine.
# Teams sharing a computer should use different ports (5433, 5434...).
DB_PORT=5432
EXTERNAL_DB_PORT=5433

# Use DATABASE_URL_LOCAL for local development (outside of Docker)
DATABASE_URL_LOCAL=postgresql+asyncpg://sandbox:sandbox@localhost:5432/sandbox_db
DATABASE_URL_LOCAL_SYNC=postgresql+psycopg2://sandbox:sandbox@localhost:5432/sandbox_db

# ── Temporal ──────────────────────────────────────────────────
TEMPORAL_NAMESPACE=default
TEMPORAL_PORT=7233
TEMPORAL_HOST=temporal
EXTERNAL_TEMPORAL_PORT=7234
TEMPORAL_UI_PORT=8080
EXTERNAL_TEMPORAL_UI_PORT=8081
POSTGRES_SEEDS=db

# Linux only. Mac/Windows can use the default UID/GID values (comment out the lines below).
# Resolves permission issues when running Docker containers on Linux by matching the host user's UID and GID.
UID=1000
GID=1000